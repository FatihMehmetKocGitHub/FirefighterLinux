#!/bin/bash

DB="$HOME/.firefighterlinux/firefighter.db"

if [ -z "$1" ]; then
    echo "Usage: ffl-import FILE.json"
    exit 1
fi

IMPORT_FILE="$1"

if [ ! -f "$IMPORT_FILE" ]; then
    echo "File not found."
    exit 1
fi

sqlite3 "$DB" "CREATE TABLE IF NOT EXISTS reports (
id INTEGER PRIMARY KEY AUTOINCREMENT,
type TEXT,
note TEXT,
latitude TEXT,
longitude TEXT,
status TEXT,
photo_path TEXT,
created_at TEXT DEFAULT CURRENT_TIMESTAMP
);"

echo "===================================="
echo " Firefighter Linux Import System"
echo "===================================="

IMPORTED=0
SKIPPED=0

jq -c '.[]' "$IMPORT_FILE" | while read -r row; do

TYPE=$(echo "$row" | jq -r '.type')
NOTE=$(echo "$row" | jq -r '.note')
LAT=$(echo "$row" | jq -r '.latitude')
LON=$(echo "$row" | jq -r '.longitude')
STATUS=$(echo "$row" | jq -r '.status')
PHOTO=$(echo "$row" | jq -r '.photo_path')
CREATED=$(echo "$row" | jq -r '.created_at')

EXISTS=$(sqlite3 "$DB" "
SELECT COUNT(*) FROM reports
WHERE type='$TYPE'
AND note='$NOTE'
AND latitude='$LAT'
AND longitude='$LON'
AND created_at='$CREATED';
")

if [ "$EXISTS" -eq 0 ]; then
sqlite3 "$DB" "
INSERT INTO reports
(type, note, latitude, longitude, status, photo_path, created_at)
VALUES
('$TYPE', '$NOTE', '$LAT', '$LON', '$STATUS', '$PHOTO', '$CREATED');
"
echo "Imported: $TYPE - $NOTE"
else
echo "Duplicate skipped: $TYPE - $NOTE"
fi

done

echo "Import completed."
