#!/bin/bash

DB="$HOME/.firefighterlinux/firefighter.db"

REPORT_COUNT=0

if [ -f "$DB" ]; then
    REPORT_COUNT=$(sqlite3 "$DB" "SELECT COUNT(*) FROM reports;")
fi

echo "===================================="
echo " Firefighter Linux BORA"
echo "===================================="

echo "Hostname      : $(hostname)"
echo "Kernel        : $(uname -r)"
echo "Uptime        : $(uptime -p)"
echo "RAM Usage     : $(free -h | awk '/Mem:/ {print $3 " / " $2}')"
echo "Disk Usage    : $(df -h / | awk 'NR==2 {print $3 " / " $2 " (" $5 ")"}')"
echo "IP Address    : $(hostname -I | awk '{print $1}')"
echo "Reports       : $REPORT_COUNT"
echo "Date          : $(date)"
echo ""
echo "Mode          : Offline-first"
echo "Status        : READY"
echo "===================================="
