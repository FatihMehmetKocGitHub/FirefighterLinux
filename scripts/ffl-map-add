#!/bin/bash

FFL_DIR="$HOME/.firefighterlinux"
DB="$FFL_DIR/firefighter.db"
MAP_DIR="$HOME/FirefighterLinux/maps"
MAP_FILE="$MAP_DIR/map-add.html"

mkdir -p "$FFL_DIR"
mkdir -p "$MAP_DIR"

echo "===================================="
echo " Firefighter Linux Map Add"
echo "===================================="

read -p "Type / Olay türü: " TYPE
read -p "Note / Not: " NOTE
read -p "Address / Adres: " ADDRESS
read -p "Status / Durum: " STATUS

if [ -z "$TYPE" ] || [ -z "$NOTE" ]; then
    echo "Type and note cannot be empty."
    exit 1
fi

cat > "$MAP_FILE" << 'EOF'
<!DOCTYPE html>
<html>
<head>
<meta charset="utf-8">
<title>Firefighter Linux Map Add</title>
<link rel="stylesheet" href="https://unpkg.com/leaflet/dist/leaflet.css"/>
<script src="https://unpkg.com/leaflet/dist/leaflet.js"></script>
<style>
body { margin: 0; font-family: Arial, sans-serif; }
#map { height: 75vh; width: 100%; }
#panel { padding: 15px; font-size: 18px; }
code { background: #eee; padding: 6px; display: inline-block; }
</style>
</head>
<body>

<div id="map"></div>

<div id="panel">
<h2>Firefighter Linux Map Add</h2>
<p>Haritaya tıkla / Click on the map</p>
<p>Enlem / Latitude: <code id="lat">-</code></p>
<p>Boylam / Longitude: <code id="lon">-</code></p>
<p>Kopyala / Copy: <code id="copy">-</code></p>
<p><b>Bu değerleri terminale yaz / paste these values into terminal.</b></p>
</div>

<script>
var map = L.map('map').setView([39.0, 35.0], 6);

L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
    maxZoom: 19
}).addTo(map);

var marker = null;

map.on('click', function(e) {
    var lat = e.latlng.lat.toFixed(6);
    var lon = e.latlng.lng.toFixed(6);

    document.getElementById("lat").textContent = lat;
    document.getElementById("lon").textContent = lon;
    document.getElementById("copy").textContent = lat + " " + lon;

    if (marker) {
        map.removeLayer(marker);
    }

    marker = L.marker([lat, lon]).addTo(map)
        .bindPopup("Selected location<br>Lat: " + lat + "<br>Lon: " + lon)
        .openPopup();
});
</script>

</body>
</html>
EOF

chmod 644 "$MAP_FILE"

echo ""
echo "Map picker created:"
echo "$MAP_FILE"
echo "Haritada konumu seç, Enlem/Boylam değerlerini terminale yaz."
echo ""

if command -v chromium-browser >/dev/null 2>&1; then
    chromium-browser "$MAP_FILE" &
elif command -v firefox >/dev/null 2>&1; then
    firefox "$MAP_FILE" &
elif command -v xdg-open >/dev/null 2>&1; then
    xdg-open "$MAP_FILE" &
fi

echo ""
read -p "Latitude / Enlem: " LAT
read -p "Longitude / Boylam: " LON

sqlite3 "$DB" "CREATE TABLE IF NOT EXISTS reports (
id INTEGER PRIMARY KEY AUTOINCREMENT,
type TEXT,
note TEXT,
address TEXT,
latitude TEXT,
longitude TEXT,
status TEXT,
photo_path TEXT,
created_at TEXT DEFAULT CURRENT_TIMESTAMP
);"

sqlite3 "$DB" "ALTER TABLE reports ADD COLUMN address TEXT;" 2>/dev/null

sqlite3 "$DB" "INSERT INTO reports (type, note, address, latitude, longitude, status, photo_path)
VALUES ('$TYPE', '$NOTE', '$ADDRESS', '$LAT', '$LON', '$STATUS', '');"

echo ""
echo "Report saved from map selection."
echo "Latitude : $LAT"
echo "Longitude: $LON"
