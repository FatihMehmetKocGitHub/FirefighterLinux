#!/bin/bash

echo "===================================="
echo " Firefighter Linux Update System"
echo "===================================="

echo ""
echo "[1/3] Updating package lists..."
sudo apt update

echo ""
echo "[2/3] Upgrading system..."
sudo apt upgrade -y

echo ""
echo "[3/3] Cleaning unnecessary packages..."
sudo apt autoremove -y

echo ""
echo "===================================="
echo " Firefighter Linux update completed"
echo "===================================="
